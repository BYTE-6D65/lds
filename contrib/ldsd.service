[Unit]
Description=Liam's Dictation Service (ldsd)
Documentation=https://github.com/BYTE-6D65/lds
After=pipewire-pulse.service pipewire.service
Wants=pipewire-pulse.service

[Service]
Type=simple
ExecStart=/usr/bin/lds daemon
Restart=on-failure
RestartSec=5

# Wayland clipboard needs these
Environment=WAYLAND_DISPLAY=wayland-1
Environment=XDG_RUNTIME_DIR=/run/user/%U

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%t

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ldsd

[Install]
WantedBy=default.target
